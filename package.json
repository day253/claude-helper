{
  "name": "llm-providers-config",
  "version": "0.2.0",
  "description": "多供应商 LLM API Key 本地配置，导出 OpenAI_* 或写入 Claude Code settings.json",
  "type": "module",
  "bin": {
    "llm-config": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "debug": "tsx --inspect-brk src/cli.ts",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.12",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
