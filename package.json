{
  "name": "claude-helper",
  "version": "0.6.8",
  "description": "Claude Code configuration wizard—helps you pick a provider and set your API key. Claude Code 配置向导：帮你选择供应商并配置 API Key。",
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "api-key",
    "llm",
    "cli",
    "settings-json"
  ],
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/day253/claude-helper.git"
  },
  "bugs": {
    "url": "https://github.com/day253/claude-helper/issues"
  },
  "homepage": "https://github.com/day253/claude-helper#readme",
  "type": "module",
  "bin": {
    "claude-helper": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "debug": "tsx --inspect-brk src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.12",
    "js-yaml": "^4.1.0",
    "ora": "^8.2.0",
    "terminal-link": "^5.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
